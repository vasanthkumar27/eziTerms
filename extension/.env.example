# Copy this to `.env` and adjust as needed.
#
# AUTH FLOW (default values below)
# ────────────────────────────────────
# • Extension "Sign in" → opens VITE_WEBSITE_BASE_URL (your LOCAL frontend at
#   http://localhost:3000). The local frontend calls the REMOTE preview
#   backend to authenticate, stores tokens in localStorage, and the extension's
#   content script syncs them into chrome.storage.
# • Extension API calls (scan, analyze, chat, upload) go to VITE_API_BASE_URL
#   — the remote preview backend — directly.
#
# To point the extension at a PRODUCTION backend + website:
#   VITE_API_BASE_URL=https://api.haptix.in/api
#   VITE_WEBSITE_BASE_URL=https://distil.haptix.in
#
# To point everything at a LOCAL backend on your machine:
#   VITE_API_BASE_URL=http://localhost:8000/api
#   VITE_WEBSITE_BASE_URL=http://localhost:3000

VITE_API_BASE_URL=https://2a64ea27-33c2-473c-a9a2-fbd58963d474.preview.emergentagent.com/api
VITE_WEBSITE_BASE_URL=http://localhost:3000

# Fallback toggle (ignored when VITE_API_BASE_URL is set)
VITE_USE_AWS=false
