# API target: true = production, false = local backend
# VITE_USE_AWS=true  → API: https://api.haptix.in | Website: https://eziterms.haptix.in
# VITE_USE_AWS=false → API: http://localhost:8000 | Website: http://localhost:5173
# Tip: use "npm run build:local" or "npm run build:prod" to override without editing .env
VITE_USE_AWS=false

# Website base URL for login/signup redirects (local: localhost:5173, prod: eziterms.haptix.in)
VITE_WEBSITE_BASE_URL=http://localhost:5173
