# Copy this to `.env` and adjust as needed.
#
# API BASE URL  (priority: VITE_API_BASE_URL > VITE_USE_AWS toggle)
# ────────────────────────────────────────────────────────────────
# Option 1 — Emergent-hosted preview (no local backend needed):
# VITE_API_BASE_URL=https://YOUR-PREVIEW-ID.preview.emergentagent.com/api
# VITE_WEBSITE_BASE_URL=https://YOUR-PREVIEW-ID.preview.emergentagent.com
#
# Option 2 — local backend on your machine (uvicorn main:app --port 8000):
# VITE_USE_AWS=false
# VITE_WEBSITE_BASE_URL=http://localhost:5173
#
# Option 3 — production:
# VITE_USE_AWS=true
# VITE_WEBSITE_BASE_URL=https://eziterms.haptix.in

VITE_API_BASE_URL=https://2a64ea27-33c2-473c-a9a2-fbd58963d474.preview.emergentagent.com/api
VITE_WEBSITE_BASE_URL=https://2a64ea27-33c2-473c-a9a2-fbd58963d474.preview.emergentagent.com
VITE_USE_AWS=false
