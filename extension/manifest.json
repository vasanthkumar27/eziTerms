{
  "manifest_version": 3,
  "name": "Distil",
  "version": "1.0",
  "key": "",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "identity",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.haptix.in/*",
    "http://localhost:8000/*",
    "http://3.109.197.65:8000/*",
    "http://localhost:5173/*"
  ],
  "action": {
    "default_title": "Distil",
    "default_icon": {
      "16": "assets/distil-Logo-icon-light-theme.png",
      "32": "assets/distil-Logo-icon-light-theme.png",
      "48": "assets/distil-Logo-icon-light-theme.png"
    }
  },
  "side_panel": {
    "default_path": "index.html",
    "openPanelOnActionClick": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "oauth2": {
    "client_id": "413722211531-cqc9a43po8eua0jgp5j15cf73pm16arg.apps.googleusercontent.com",
    "scopes": [
      "email",
      "profile"
    ]
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "models/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}